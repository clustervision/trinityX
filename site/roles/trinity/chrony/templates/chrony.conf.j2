# {{ ansible_managed }}

# Upstream servers
{% if chrony_upstream_servers %}
{% for server in chrony_upstream_servers %}
server {{ server }} iburst
{% endfor %}
{% endif %}

# Ignore stratum in source selection.
stratumweight 0

# Record the rate at which the system clock gains/losses time.
driftfile /var/lib/chrony/drift

# Enable kernel RTC synchronization.
rtcsync

# In first three updates step the system clock instead of slew
# if the adjustment is larger than 10 seconds.
makestep 10 3

{% if chrony_as_server %}
# Allow NTP client access from local network.
{% if chrony_allow_networks %}
{% for server in chrony_allow_networks %}
allow {{ net }}
{% endfor %}
{% else %}
allow
{% endif %}

# Serve time even if not synchronized to any NTP server.
local stratum 10
{% endif %}

# Listen for commands only on localhost.
bindcmdaddress 127.0.0.1
bindcmdaddress ::1

# keyfile deprecated for EL9
keyfile /etc/chrony.keys

{% if chrony_upstream_servers %}
# Force a sync even when time has drifted too far
initstepslew 30
{%- for server in chrony_upstream_servers %}
 {{ server }}
{%- endfor %}
{% endif %}

#
# Specify the key used as password for chronyc. Deprecated for EL9
commandkey 1

# Generate command key if missing. Deprecated for EL9
generatecommandkey

# Disable logging of client accesses.
noclientlog

# Send a message to syslog if a clock adjustment is larger than 0.5 seconds.
logchange 0.5

logdir /var/log/chrony
#log measurements statistics tracking
